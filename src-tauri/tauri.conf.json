{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Nem3D",
  "version": "0.1.1",
  "identifier": "dk.sigurd.nem3d",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://127.0.0.1:5173",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Nem3D",
        "width": 1280,
        "height": 820,
        "minWidth": 1024,
        "minHeight": 720,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": [
      "nsis"
    ],
    "publisher": "Sigurd",
    "windows": {
      "nsis": {
        "displayLanguageSelector": false
      }
    },
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "active": true,
      "endpoints": [
        "https://github.com/jrgamerdude/Nem3D/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDcxOUJBMTBBNkE2QkY1RDkKUldUWjlXdHFDcUdiY1RFT3JBdVAzWThIQVZZRTN2U01SbS92cTBEcFh5U2daOEJvdUh3SHRxNUUK"
    }
  }
}
